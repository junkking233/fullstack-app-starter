page {
  min-height: 100vh;
  background: #f5f7fb;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 40rpx;
}

.muted {
  color: #6b7280;
}

.action-button {
  height: 88rpx;
  border-radius: 8rpx;
  background: #13b45d;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-button.is-disabled {
  opacity: 0.65;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.page.has-bottom-action {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}
