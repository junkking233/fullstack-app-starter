page {
  min-height: 100%;
  background: #f7f8fa;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  background: #f7f8fa;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  margin: 24rpx 28rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.06);
}

.title {
  color: #111827;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.muted {
  color: #6b7280;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price {
  color: #ef4444;
  font-weight: 800;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  background: #13b45d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-button[disabled] {
  background: #a7e8c4;
  color: #f0fdf4;
}

.primary-button.is-disabled {
  background: #a7e8c4;
  color: #f0fdf4;
}

.plain-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 40rpx;
  background: #ffffff;
  color: #334155;
  font-size: 28rpx;
}

.add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #13b45d;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 140rpx 40rpx;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 112rpx;
}

.empty-text {
  display: block;
  margin-top: 22rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.bottom-space {
  height: 140rpx;
}
