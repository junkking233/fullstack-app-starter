<view class="page mine-page">
  <view class="user-header">
    <view class="profile">
      <view class="avatar">{{avatarText}}</view>
      <view class="user-info">
        <text class="username">{{user.username || '微信用户'}}</text>
        <text class="member-level">{{isLoggedIn ? roleText : '登录后查看会员权益'}}</text>
      </view>
    </view>
  </view>

  <view class="stats">
    <view class="stat-item" bindtap="goOrders">
      <text class="stat-value">{{orderCount}}</text>
      <text class="stat-label">订单</text>
    </view>
    <view class="stat-item" bindtap="goCoupons">
      <text class="stat-value">{{couponCount}}</text>
      <text class="stat-label">优惠券</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{points}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-item" bindtap="goAddresses">
      <text class="stat-value">{{addressCount}}</text>
      <text class="stat-label">地址</text>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="goOrders">
      <text class="menu-icon">📦</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goCoupons">
      <text class="menu-icon">🎟</text>
      <text class="menu-text">优惠券</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAddresses">
      <text class="menu-icon">📍</text>
      <text class="menu-text">收货地址</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <text class="menu-icon">💬</text>
      <text class="menu-text">在线客服</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view wx:if="{{!isLoggedIn}}" class="primary-button account-button" bindtap="goLogin">登录</view>
  <view wx:else class="logout-button" bindtap="onLogout">退出登录</view>
</view>
