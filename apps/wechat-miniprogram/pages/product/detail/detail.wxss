.detail-page {
  min-height: 100vh;
  overflow: visible;
  padding-bottom: calc(136rpx + env(safe-area-inset-bottom));
  background: #f6f7f8;
}

.detail-hero {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 430rpx;
  padding: 44rpx;
  overflow: hidden;
  background: #ffffff;
  color: #111827;
}

.hero-plate {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 300rpx;
  border-radius: 34rpx;
  background: #ecfdf3;
  color: #0f172a;
  font-size: 96rpx;
  font-weight: 900;
}

.detail-content {
  margin-top: -38rpx;
  padding-bottom: 1rpx;
}

.info-card {
  position: relative;
  z-index: 2;
  margin-top: 0;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.detail-title {
  display: block;
  flex: 1;
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.35;
}

.fresh-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #ecfdf3;
  color: #13b45d;
  font-size: 24rpx;
  font-weight: 900;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag {
  padding: 9rpx 17rpx;
  border-radius: 999rpx;
  background: #ecfdf3;
  color: #13b45d;
  font-size: 23rpx;
  font-weight: 700;
}

.hot-tag {
  background: #dcfce7;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  margin-top: 24rpx;
}

.detail-price {
  color: #ef4444;
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.detail-spec,
.sales,
.desc,
.param-label {
  color: #6b7280;
  font-size: 26rpx;
}

.sales,
.desc {
  display: block;
  margin-top: 14rpx;
  line-height: 1.7;
}

.note-box {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.note-label {
  display: block;
  margin-bottom: 8rpx;
  color: #111827;
  font-size: 25rpx;
  font-weight: 800;
}

.delivery-note {
  display: block;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.65;
}

.card-title {
  display: block;
  margin-bottom: 14rpx;
  color: #111827;
  font-size: 29rpx;
  font-weight: 800;
}

.param-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 74rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.param-row:last-child {
  border-bottom: 0;
}

.param-value {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.bottom-actions {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 28rpx calc(22rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 30rpx 30rpx 0 0;
  box-shadow: 0 -8rpx 26rpx rgba(15, 23, 42, 0.1);
}

.cart-action,
.buy-action {
  flex: 1;
  height: 84rpx;
  margin: 0;
  padding: 0;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 800;
  text-align: center;
}

.cart-action {
  background: #ff9f43;
  color: #ffffff;
}

.buy-action {
  background: #13b45d;
  color: #ffffff;
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-bottom-space {
  height: calc(168rpx + env(safe-area-inset-bottom));
}
