<view class="page register-page">
  <view class="register-hero">
    <view class="brand-mark">鲜</view>
    <view>
      <view class="register-title">创建鲜享账号</view>
      <view class="register-subtitle">注册后可体验购物车、下单和会员中心</view>
    </view>
  </view>

  <view class="register-card">
    <van-cell-group inset>
      <van-field value="{{username}}" label="账号" placeholder="请输入账号" clearable bind:change="onUsernameChange" />
      <van-field value="{{email}}" label="邮箱" placeholder="请输入邮箱" clearable bind:change="onEmailChange" />
      <van-field value="{{password}}" label="密码" placeholder="请输入密码" password clearable bind:change="onPasswordChange" />
      <van-field value="{{confirmPassword}}" label="确认" placeholder="请再次输入密码" password clearable bind:change="onConfirmPasswordChange" />
    </van-cell-group>

    <view class="primary-button register-button {{loading ? 'is-disabled' : ''}}" bindtap="onSubmit">
      {{loading ? '注册中...' : '注册并登录'}}
    </view>
    <view class="login-link" bindtap="goLogin">已有账号？返回登录</view>
  </view>

  <van-toast id="van-toast" />
</view>
