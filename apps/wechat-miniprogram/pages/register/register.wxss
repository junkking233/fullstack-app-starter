.register-page {
  min-height: 100vh;
  padding: 0 28rpx 48rpx;
  background: #f7f8fa;
}

.register-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 0 -28rpx;
  padding: 112rpx 44rpx 92rpx;
  border-radius: 0 0 56rpx 56rpx;
  background: linear-gradient(135deg, #2ecc71, #13b45d);
  color: #ffffff;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: #ffffff;
  color: #13b45d;
  font-size: 44rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 34rpx rgba(15, 23, 42, 0.12);
}

.register-title {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.register-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 25rpx;
  line-height: 1.5;
}

.register-card {
  position: relative;
  margin-top: -52rpx;
  padding: 34rpx 0 36rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.1);
}

.register-button {
  margin: 34rpx 34rpx 0;
}

.login-link {
  margin-top: 28rpx;
  color: #13b45d;
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
}
