.order-list {
  padding: 20rpx 28rpx;
}

.order-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.05);
}

.order-head,
.order-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-no {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.order-status {
  color: #13b45d;
  font-size: 26rpx;
  font-weight: 800;
}

.order-products {
  margin: 22rpx 0;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f9fafb;
}

.order-product {
  display: block;
  margin-bottom: 8rpx;
  color: #374151;
  font-size: 26rpx;
}

.order-product:last-child {
  margin-bottom: 0;
}

.order-amount {
  color: #ef4444;
  font-size: 34rpx;
  font-weight: 900;
}

.empty-action {
  width: 260rpx;
  margin: 32rpx auto 0;
}
