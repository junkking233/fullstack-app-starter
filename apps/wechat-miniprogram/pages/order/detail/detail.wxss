.status {
  display: block;
  margin-bottom: 18rpx;
  color: #13b45d;
  font-size: 42rpx;
  font-weight: 900;
}

.card-title {
  display: block;
  margin-bottom: 16rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.info-line {
  display: block;
  margin-top: 10rpx;
  color: #111827;
  font-size: 27rpx;
}

.detail-item,
.fee-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.detail-item:last-child,
.fee-row:last-child {
  border-bottom: 0;
}

.item-name {
  flex: 1;
  margin-right: 20rpx;
  color: #374151;
  font-size: 26rpx;
}

.item-price,
.pay {
  color: #ef4444;
  font-size: 28rpx;
  font-weight: 900;
}
