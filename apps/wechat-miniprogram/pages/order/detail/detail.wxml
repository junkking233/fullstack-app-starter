<view class="page">
  <view wx:if="{{order}}">
    <view class="card">
      <text class="status">{{order.status}}</text>
      <text class="muted">订单号：{{order.id}}</text>
      <text class="muted">下单时间：{{order.createdAt}}</text>
    </view>

    <view class="card">
      <text class="card-title">配送信息</text>
      <text class="info-line">{{order.address.name}} {{order.address.phone}}</text>
      <text class="info-line muted">{{order.address.region}} {{order.address.detail}}</text>
      <text class="info-line muted">配送时间：{{order.deliveryTime}}</text>
    </view>

    <view class="card">
      <text class="card-title">商品清单</text>
      <view class="detail-item" wx:for="{{order.items}}" wx:key="id">
        <text class="item-name ellipsis">{{item.product.name}} × {{item.quantity}}</text>
        <text class="item-price">¥{{item.amountText}}</text>
      </view>
    </view>

    <view class="card">
      <view class="fee-row">
        <text>商品金额</text>
        <text>¥{{totalAmountText}}</text>
      </view>
      <view class="fee-row">
        <text>实付金额</text>
        <text class="pay">¥{{payAmountText}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="empty">
    <text class="empty-icon">📦</text>
    <text class="empty-text">订单不存在</text>
  </view>
</view>
