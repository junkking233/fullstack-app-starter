<view class="page checkout-page">
  <scroll-view scroll-y class="checkout-scroll">
    <view class="card" bindtap="selectAddress">
      <view class="form-row">
        <text class="form-label">收货地址</text>
        <view class="form-value-wrap">
          <text class="form-value">{{addressText}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="form-row">
        <text class="form-label">配送方式</text>
        <view class="pill-group">
          <text class="pill {{deliveryType === 'HOME' ? 'active' : ''}}" bindtap="setDelivery" data-type="HOME">到家配送</text>
          <text class="pill {{deliveryType === 'STORE' ? 'active' : ''}}" bindtap="setDelivery" data-type="STORE">门店自提</text>
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">配送时间</text>
        <text class="form-value">今天 18:00-19:00</text>
      </view>
    </view>

    <view class="card" bindtap="selectCoupon">
      <view class="form-row">
        <text class="form-label">优惠券</text>
        <view class="form-value-wrap">
          <text class="form-value active-value">{{coupon ? coupon.name : '选择优惠券'}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <view class="card">
      <text class="card-title">商品清单</text>
      <view class="checkout-item" wx:for="{{items}}" wx:key="id">
        <text class="item-name ellipsis">{{item.product.name}} × {{item.quantity}}</text>
        <text class="item-price">¥{{item.amountText}}</text>
      </view>
    </view>

    <view class="card">
      <view class="fee-row">
        <text>商品金额</text>
        <text>¥{{totalAmountText}}</text>
      </view>
      <view class="fee-row">
        <text>配送费</text>
        <text>¥0.00</text>
      </view>
      <view class="fee-row" wx:if="{{coupon}}">
        <text>优惠券</text>
        <text class="discount">-¥{{coupon.discountText}}</text>
      </view>
    </view>
    <view class="bottom-space"></view>
  </scroll-view>

  <view class="submit-bar">
    <view>
      <text class="submit-label">实付：</text>
      <text class="submit-price">¥{{payAmountText}}</text>
    </view>
    <view class="submit-btn" bindtap="submitOrder">提交订单</view>
  </view>
</view>
