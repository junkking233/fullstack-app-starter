.checkout-page {
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.checkout-scroll {
  height: calc(100vh - 132rpx - env(safe-area-inset-bottom));
  padding-top: 8rpx;
}

.form-row,
.fee-row,
.checkout-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.form-row:last-child,
.fee-row:last-child,
.checkout-item:last-child {
  border-bottom: 0;
}

.form-label {
  min-width: 150rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.form-value-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
  min-width: 0;
}

.form-value {
  color: #6b7280;
  font-size: 26rpx;
}

.active-value,
.arrow {
  color: #13b45d;
}

.pill-group {
  display: flex;
  gap: 14rpx;
}

.pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 24rpx;
}

.pill.active {
  background: #ecfdf3;
  color: #13b45d;
  font-weight: 800;
}

.card-title {
  display: block;
  margin-bottom: 12rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.item-name {
  flex: 1;
  margin-right: 20rpx;
  color: #374151;
  font-size: 26rpx;
}

.item-price,
.discount {
  color: #ef4444;
  font-size: 26rpx;
  font-weight: 800;
}

.submit-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -6rpx 20rpx rgba(15, 23, 42, 0.08);
}

.submit-label {
  color: #111827;
  font-size: 28rpx;
}

.submit-price {
  color: #ef4444;
  font-size: 42rpx;
  font-weight: 900;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 86rpx;
  margin: 0;
  padding: 0 50rpx;
  border-radius: 43rpx;
  background: #13b45d;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}
