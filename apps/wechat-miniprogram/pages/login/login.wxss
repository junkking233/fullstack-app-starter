.login-page {
  min-height: 100vh;
  padding: 0 28rpx 48rpx;
  background: #f7f8fa;
}

.login-hero {
  margin: 0 -28rpx;
  padding: 112rpx 44rpx 92rpx;
  border-radius: 0 0 56rpx 56rpx;
  background: linear-gradient(135deg, #2ecc71, #13b45d);
  color: #ffffff;
}

.brand {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: #ffffff;
  color: #13b45d;
  font-size: 44rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 34rpx rgba(15, 23, 42, 0.12);
}

.login-title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.2;
}

.login-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

.benefits {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 36rpx;
}

.benefits text {
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 700;
}

.login-card {
  position: relative;
  margin-top: -52rpx;
  padding: 34rpx 0 36rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.1);
}

.card-heading {
  padding: 0 34rpx 24rpx;
}

.card-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
}

.card-desc {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.login-button {
  margin: 34rpx 34rpx 0;
}

.register-link {
  margin-top: 28rpx;
  color: #13b45d;
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
}
