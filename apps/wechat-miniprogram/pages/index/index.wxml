<view class="page home-page">
  <view class="topbar">
    <view class="toprow">
      <view>
        <text class="brand">鲜绿优选</text>
        <text class="location">绿城花园店 · 30分钟送达</text>
      </view>
    </view>
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索水果、蔬菜、肉禽蛋" value="{{keyword}}" bindinput="onInput" bindconfirm="doSearch" />
    </view>
  </view>

  <scroll-view scroll-y class="scroll-content">
    <swiper class="banner-swiper" indicator-dots indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#13b45d" autoplay circular>
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-item">
          <view>
            <text class="banner-title">{{item.title}}</text>
            <text class="banner-desc">{{item.desc}}</text>
          </view>
          <text class="banner-emoji">🥬</text>
        </view>
      </swiper-item>
    </swiper>

    <view class="category-grid">
      <view class="cat-item" wx:for="{{categories}}" wx:key="id" bindtap="goCategory" data-id="{{item.id}}">
        <text class="cat-icon">{{item.icon}}</text>
        <text class="cat-name">{{item.name}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">
        <text class="section-left">今日爆款</text>
        <text class="section-more" bindtap="goCategoryList">查看更多</text>
      </view>
      <view class="product-grid">
        <view class="product-card" wx:for="{{hotProducts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <view class="product-img" style="background: {{item.color}};">
            <text>{{item.imageText}}</text>
          </view>
          <view class="product-info">
            <text class="product-name ellipsis">{{item.name}}</text>
            <text class="product-spec">{{item.spec}} · 已售{{item.sales}}</text>
            <view class="product-bottom">
              <text class="price">¥{{item.priceText}}</text>
              <view class="add-button" catchtap="onAdd" data-id="{{item.id}}">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">
        <text class="section-left">限时秒杀</text>
        <text class="section-time">18:00结束</text>
      </view>
      <scroll-view scroll-x class="h-scroll" enable-flex>
        <view class="seckill-card" wx:for="{{seckillProducts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <view class="seckill-img" style="background: {{item.color}};">{{item.imageText}}</view>
          <text class="seckill-name ellipsis">{{item.name}}</text>
          <view>
            <text class="price">¥{{item.priceText}}</text>
            <text class="origin-price">¥{{item.originalPriceText}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="section">
      <view class="section-title">
        <text class="section-left">新品上架</text>
      </view>
      <view class="product-grid">
        <view class="product-card" wx:for="{{newProducts}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <view class="product-img" style="background: {{item.color}};">
            <text>{{item.imageText}}</text>
          </view>
          <view class="product-info">
            <text class="product-name ellipsis">{{item.name}}</text>
            <text class="product-spec">{{item.spec}}</text>
            <view class="product-bottom">
              <text class="price">¥{{item.priceText}}</text>
              <view class="add-button" catchtap="onAdd" data-id="{{item.id}}">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>
</view>
