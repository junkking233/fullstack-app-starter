<view class="page cart-page">
  <scroll-view scroll-y class="cart-scroll">
    <view wx:if="{{items.length > 0}}">
      <view class="cart-item" wx:for="{{items}}" wx:key="id">
        <checkbox checked="{{item.checked}}" color="#13b45d" bindtap="toggleChecked" data-id="{{item.id}}" />
        <view class="cart-img" style="background: {{item.product.color}};">{{item.product.imageText}}</view>
        <view class="cart-info">
          <text class="cart-name ellipsis">{{item.product.name}}</text>
          <text class="cart-spec">{{item.product.spec}}</text>
          <view class="cart-bottom">
            <text class="price">¥{{item.priceText}}</text>
            <view class="stepper">
              <text class="step-btn" bindtap="decrease" data-id="{{item.id}}">-</text>
              <text class="step-count">{{item.quantity}}</text>
              <text class="step-btn" bindtap="increase" data-id="{{item.id}}">+</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="empty">
      <text class="empty-icon">🛒</text>
      <text class="empty-text">购物车还是空的</text>
      <view class="primary-button empty-action" bindtap="goHome">去逛逛</view>
    </view>
    <view class="bottom-space"></view>
  </scroll-view>

  <view wx:if="{{items.length > 0}}" class="checkout-bar">
    <view>
      <text class="checkout-label">合计：</text>
      <text class="checkout-price">¥{{totalAmountText}}</text>
    </view>
    <view class="checkout-btn" bindtap="goCheckout">去结算({{totalCount}})</view>
  </view>
</view>
