.cart-page {
  padding-bottom: 140rpx;
}

.cart-scroll {
  height: calc(100vh - 140rpx);
  padding: 20rpx 28rpx;
}

.cart-scroll .empty {
  min-height: 620rpx;
  padding-top: 0;
  padding-bottom: 0;
}

.cart-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.05);
}

.cart-img {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 150rpx;
  height: 150rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.cart-info {
  flex: 1;
  min-width: 0;
}

.cart-name {
  display: block;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.cart-spec {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.cart-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.stepper {
  display: flex;
  align-items: center;
  overflow: hidden;
  border: 1rpx solid #e5e7eb;
  border-radius: 28rpx;
}

.step-btn,
.step-count {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 52rpx;
  color: #374151;
  font-size: 28rpx;
}

.step-count {
  width: 64rpx;
  background: #f9fafb;
}

.checkout-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #ffffff;
  box-shadow: 0 -6rpx 20rpx rgba(15, 23, 42, 0.08);
}

.checkout-label {
  color: #111827;
  font-size: 28rpx;
}

.checkout-price {
  color: #ef4444;
  font-size: 40rpx;
  font-weight: 800;
}

.checkout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  margin: 0;
  padding: 0 46rpx;
  border-radius: 42rpx;
  background: #13b45d;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.empty-action {
  width: 260rpx;
  margin: 32rpx auto 0;
}
